# Copy to .env.local (git-ignored) for local dev, and set the same values in
# your Vercel project's Environment Variables for production.

# --- Gemini (LLM), server-side only -----------------------------------------
# Read only by the dev proxy / Vercel function — never shipped to the browser.
GEMINI_API_KEY=
# Optional: override the model (default: gemini-flash-latest, free tier)
GEMINI_MODEL=

# --- Supabase (cloud login + session sync), safe in the browser -------------
# Both are exposed to the client (VITE_ prefix). This is intentional and safe:
# the anon key is public by design and Row Level Security (supabase/schema.sql)
# is the real security boundary. Leave these unset to run purely local (no
# login; sessions stay in this browser's IndexedDB only).
# Find them in Supabase: Dashboard -> Project Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
